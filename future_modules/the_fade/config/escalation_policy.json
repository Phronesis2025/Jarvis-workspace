{
  "_meta": {
    "title": "escalation_policy",
    "prompt_number": 5,
    "phase_number": 1,
    "tranche_number": 1
  },
  "policy_version": "0.1.0",
  "rules": [
    {
      "failure_type": "SOURCE_UNAVAILABLE",
      "behavior": "record_scout_failure_downgrade_or_continue_if_non_critical",
      "can_continue": true
    },
    {
      "failure_type": "UNDEFINED_DIRECTION_MODEL",
      "behavior": "stop_scoring_escalate",
      "can_continue": false
    },
    {
      "failure_type": "NORMALIZATION_FAILURE",
      "behavior": "write_scout_failure_may_continue_other_lanes",
      "can_continue": true
    },
    {
      "failure_type": "MISSING_REQUIRED_LANE",
      "behavior": "policy_defined_weak_or_conflict_in_fusion_phase",
      "can_continue": true
    },
    {
      "failure_type": "INVALID_PACKET_OUTPUT",
      "behavior": "stop_no_write_escalate",
      "can_continue": false
    }
  ]
}

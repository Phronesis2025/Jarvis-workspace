{
  "title": "conflict_packet",
  "$comment": "Prompt #: 5 | Phase #: 1 | Tranche #: 1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.local/schemas/the_fade/conflict_packet.schema.json",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "conflict_packet_id",
    "task_id",
    "ticker",
    "created_at",
    "summary",
    "conflict_reasons",
    "evidence_paths"
  ],
  "properties": {
    "conflict_packet_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "ticker": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "summary": { "type": "string" },
    "conflict_reasons": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "evidence_paths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": { "type": "string" }
  }
}

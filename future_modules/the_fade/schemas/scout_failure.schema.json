{
  "title": "scout_failure",
  "$comment": "Prompt #: 5 | Phase #: 1 | Tranche #: 1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.local/schemas/the_fade/scout_failure.schema.json",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "failure_id",
    "stage",
    "error_type",
    "error_summary",
    "created_at",
    "escalation_required",
    "resolved"
  ],
  "properties": {
    "failure_id": { "type": "string", "minLength": 1 },
    "stage": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string" },
    "ticker": { "type": "string" },
    "error_type": { "type": "string", "minLength": 1 },
    "error_summary": { "type": "string" },
    "raw_context_path": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "escalation_required": { "type": "boolean" },
    "resolved": { "type": "boolean" }
  }
}

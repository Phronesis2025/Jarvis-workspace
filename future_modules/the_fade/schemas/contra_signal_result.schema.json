{
  "title": "contra_signal_result",
  "$comment": "Prompt #: 5 | Phase #: 1 | Tranche #: 1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.local/schemas/the_fade/contra_signal_result.schema.json",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "task_id",
    "ticker",
    "contra_score",
    "contra_reasons",
    "penalty_applied",
    "force_conflict",
    "notes"
  ],
  "properties": {
    "task_id": { "type": "string", "minLength": 1 },
    "ticker": { "type": "string", "minLength": 1 },
    "contra_score": { "type": "number" },
    "contra_reasons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "penalty_applied": { "type": "number" },
    "force_conflict": { "type": "boolean" },
    "notes": { "type": "string" }
  }
}

{
  "title": "signal_packet",
  "$comment": "Prompt #: 5 | Phase #: 1 | Tranche #: 1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.local/schemas/the_fade/signal_packet.schema.json",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "signal_packet_id",
    "task_id",
    "ticker",
    "asset_type",
    "composite_score",
    "signal",
    "source_breakdown",
    "conflict_flag",
    "evidence_paths",
    "operator_notes",
    "completed_at"
  ],
  "properties": {
    "signal_packet_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "ticker": { "type": "string", "minLength": 1 },
    "asset_type": {
      "type": "string",
      "enum": ["equity", "crypto", "etf", "macro", "other"]
    },
    "composite_score": { "type": "number" },
    "signal": {
      "type": "string",
      "enum": [
        "STRONG_BULLISH",
        "BULLISH",
        "WEAK_BULLISH",
        "NO_SIGNAL",
        "WEAK_BEARISH",
        "BEARISH",
        "STRONG_BEARISH",
        "CONFLICT"
      ]
    },
    "source_breakdown": { "type": "object", "additionalProperties": true },
    "conflict_flag": { "type": "boolean" },
    "evidence_paths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "operator_notes": { "type": "string" },
    "completed_at": { "type": "string", "format": "date-time" }
  }
}

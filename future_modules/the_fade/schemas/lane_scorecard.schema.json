{
  "title": "lane_scorecard",
  "$comment": "Prompt #: 5 | Phase #: 1 | Tranche #: 1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.local/schemas/the_fade/lane_scorecard.schema.json",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "task_id",
    "ticker",
    "source_lane",
    "source_name",
    "score",
    "max_score",
    "direction_model",
    "conditions_hit",
    "conditions_missed",
    "bullish_subscore",
    "bearish_subscore",
    "freshness_ok",
    "evidence_count",
    "confidence_band",
    "notes"
  ],
  "properties": {
    "task_id": { "type": "string", "minLength": 1 },
    "ticker": { "type": "string", "minLength": 1 },
    "source_lane": { "type": "string", "minLength": 1 },
    "source_name": { "type": "string", "minLength": 1 },
    "score": { "type": "number" },
    "max_score": { "type": "number" },
    "direction_model": {
      "type": "string",
      "enum": ["FOLLOW", "INVERSE", "CONTEXT_ONLY", "REGIME_CONDITIONAL"]
    },
    "conditions_hit": {
      "type": "array",
      "items": { "type": "string" }
    },
    "conditions_missed": {
      "type": "array",
      "items": { "type": "string" }
    },
    "bullish_subscore": { "type": "number" },
    "bearish_subscore": { "type": "number" },
    "freshness_ok": { "type": "boolean" },
    "evidence_count": { "type": "integer", "minimum": 0 },
    "confidence_band": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "notes": { "type": "string" }
  }
}

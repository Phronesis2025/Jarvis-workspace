{
  "title": "scanner_candidate_set",
  "$comment": "Prompt #: 5 | Phase #: 1 | Tranche #: 1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.local/schemas/the_fade/scanner_candidate_set.schema.json",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "scan_id",
    "created_at",
    "scan_reason",
    "market_session_context",
    "candidate_count",
    "candidates"
  ],
  "properties": {
    "scan_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "scan_reason": { "type": "string" },
    "market_session_context": { "type": "string" },
    "candidate_count": { "type": "integer", "minimum": 0 },
    "candidates": {
      "type": "array",
      "items": { "$ref": "#/$defs/candidate" }
    }
  },
  "$defs": {
    "candidate": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "ticker",
        "asset_type",
        "scanner_reasons",
        "scanner_score",
        "freshness_context",
        "source_tags",
        "notes"
      ],
      "properties": {
        "ticker": { "type": "string", "minLength": 1 },
        "asset_type": {
          "type": "string",
          "enum": ["equity", "crypto", "etf", "macro", "other"]
        },
        "scanner_reasons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "scanner_score": { "type": "number" },
        "freshness_context": { "type": "string" },
        "source_tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": { "type": "string" }
      }
    }
  }
}

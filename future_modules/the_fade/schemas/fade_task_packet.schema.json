{
  "title": "fade_task_packet",
  "$comment": "Prompt #: 5 | Phase #: 1 | Tranche #: 1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.local/schemas/the_fade/fade_task_packet.schema.json",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "task_id",
    "created_at",
    "tickers"
  ],
  "properties": {
    "task_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "tickers": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "status": {
      "type": "string",
      "enum": ["queued", "in_progress", "done", "escalated", "cancelled"]
    },
    "notes": { "type": "string" },
    "policy_version": { "type": "string" }
  }
}

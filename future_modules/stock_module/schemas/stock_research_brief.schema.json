{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "future_modules/stock_module/schemas/stock_research_brief",
  "title": "Stock Research Brief",
  "description": "Per-symbol research brief with catalysts, risks, and evidence",
  "type": "object",
  "required": ["report_id", "packet_id", "created_at", "symbols", "briefs"],
  "properties": {
    "report_id": {
      "type": "string",
      "description": "Unique identifier for this report"
    },
    "packet_id": {
      "type": "string",
      "description": "ID of the watchlist packet"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp"
    },
    "symbols": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Symbols covered in this report"
    },
    "briefs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["symbol", "thesis_or_watch_reason", "catalyst_summary", "risk_summary", "confidence_band", "review_recommendation"],
        "properties": {
          "symbol": { "type": "string" },
          "thesis_or_watch_reason": { "type": "string" },
          "catalyst_summary": { "type": "string" },
          "risk_summary": { "type": "string" },
          "evidence_sources": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "type": "string" },
                "title": { "type": "string" },
                "date": { "type": "string" },
                "url": { "type": "string", "format": "uri" }
              }
            }
          },
          "open_questions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "confidence_band": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "review_recommendation": {
            "type": "string",
            "description": "Advisory: monitor, dig deeper, pass, flag for discussion"
          }
        }
      },
      "description": "One brief per symbol"
    }
  }
}
